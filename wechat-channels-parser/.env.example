# ─────────────────────────────────────────────────────────────────────────
# 路径 1：会话内容存档（msgaudit）凭据
# 详见 docs/msgaudit_setup.md
# ─────────────────────────────────────────────────────────────────────────

# 企业 ID（ww 开头）— 「我的企业 → 企业信息」
WECHAT_CORP_ID=ww_xxxxxxxxxxxxxxxx

# 会话存档专用 Secret — 「管理工具 → 聊天内容存档 → 查看 Secret」
# 注意：这不是微信客服 Secret，也不是自建应用 Secret
WECHAT_MSGAUDIT_SECRET=secret_replace_me

# RSA 私钥 PEM 文件路径（绝对路径建议）
# 公钥配上后台时拿到 publickey_ver；私钥本地保管，**禁止入库**
RSA_PRIVATE_KEY_PATH=/absolute/path/to/rsa_private_key.pem

# ─────────────────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────────────────
MSGAUDIT_POLL_INTERVAL_SECONDS=10
MSGAUDIT_BATCH_LIMIT=1000

# 飞书私信收件人（默认是程万云）
LARK_USER_OPEN_ID=ou_f0c95a038d620a1cdb7256bb681f149b

LOG_LEVEL=INFO
STATE_FILE_PATH=./data/state.json
