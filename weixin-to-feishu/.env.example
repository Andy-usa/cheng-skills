# weixin-to-feishu 环境变量模板
# 拷贝为 .env 后填入实际值；.env 已在 .gitignore 中排除

# ============================================================
# ASR Provider 选择
#   auto       —— 默认，先试火山，失败 fallback 到百炼
#   volc       —— 仅火山引擎 BigASR
#   dashscope  —— 仅阿里云百炼 qwen3-asr-flash
# ============================================================
ASR_PROVIDER=auto

# ============================================================
# 火山引擎 录音文件识别大模型 标准版（默认）
# 在火山控制台 → 语音技术 → 录音文件识别大模型 → 应用管理 → 服务接口认证信息 拿
# https://console.volcengine.com/speech/service/8
# ============================================================
VOLC_ASR_APP_KEY=
VOLC_ASR_ACCESS_KEY=

# ============================================================
# 阿里云百炼（fallback / 旧版）
# 用于 auto 模式下火山失败后的兜底，或 ASR_PROVIDER=dashscope 时使用
# 通常已作为平台级 env 注入，本地开发时手动填
# ============================================================
DASHSCOPE_API_KEY=

# ============================================================
# 飞书：用于推送转录完成通知（如果你单独跑 transcribe.py 这两项不必填）
# ============================================================
LARK_USER_OPEN_ID=ou_f0c95a038d620a1cdb7256bb681f149b
