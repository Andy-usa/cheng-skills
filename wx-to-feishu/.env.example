# wx-to-feishu 环境变量模板
# 拷贝为 .env 后填入实际值

# ===== chatlog 服务地址 =====
CHATLOG_BASE_URL=http://127.0.0.1:5030

# ===== 飞书 =====
# 推送私信的目标用户 open_id（默认是程万云本人）
LARK_USER_OPEN_ID=ou_f0c95a038d620a1cdb7256bb681f149b

# 文档创建到的飞书文件夹 token（可选，留空则建在根目录）
# FEISHU_FOLDER_TOKEN=

# ===== 调用现有 wechat-to-lark skill =====
# wechat-to-lark 项目根目录的绝对路径
WECHAT_TO_LARK_DIR=/Users/cheng/cheng-skills/wechat-to-lark

# ===== Worker 行为 =====
# chatlog 轮询间隔（秒）
POLL_INTERVAL_SECONDS=5

# 已处理消息去重数据库
PROCESSED_DB=./data/state.db

# 启动后只处理这个时间点之后的消息（ISO8601；留空则从启动时刻开始）
# 用于避免重启 worker 时把历史消息全部重处理
# START_FROM=2026-05-05T00:00:00+08:00

# 日志等级
LOG_LEVEL=INFO
