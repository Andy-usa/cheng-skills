#!/usr/bin/env python3
"""
Cloud `dreamina` shim — translates dreamina CLI invocations to jimeng-cli
so make_video.py runs unchanged on remote sandboxes.

Translates:
  dreamina text2image  --prompt=X --ratio=Y --model_version=5.0 \
                       --resolution_type=2k --poll=90
  dreamina image2image --images=PATH --prompt=X --ratio=Y \
                       --model_version=5.0 --resolution_type=2k --poll=90

into:
  jimeng image generate --prompt X --model jimeng-5.0 --ratio Y \
                        --resolution 2k --output-dir TMP --json
  jimeng image edit     --prompt X --image PATH --model jimeng-5.0 \
                        --ratio Y --resolution 2k --output-dir TMP --json

Output JSON shape (stdout) matches what make_video.py expects:
  {"result_json": {"images": [{"image_url": "file:///abs/path/to/image.png"}]}}
"""

import json, os, subprocess, sys, tempfile, pathlib


def parse_args(argv):
    """Parse `--key=value` (or `--key value`) into a dict; return (subcmd, kwargs)."""
    if not argv:
        return None, {}
    sub, rest = argv[0], argv[1:]
    out = {}
    i = 0
    while i < len(rest):
        a = rest[i]
        if a.startswith("--") and "=" in a:
            k, v = a[2:].split("=", 1)
            out[k] = v
            i += 1
        elif a.startswith("--"):
            k = a[2:]
            v = rest[i + 1] if i + 1 < len(rest) and not rest[i + 1].startswith("--") else "true"
            out[k] = v
            i += 2
        else:
            i += 1
    return sub, out


def map_model(version: str) -> str:
    """`5.0` -> `jimeng-5.0`. Already-prefixed values pass through."""
    v = (version or "5.0").strip()
    return v if v.startswith("jimeng-") else f"jimeng-{v}"


def run_jimeng(jimeng_args, tmp_dir):
    cmd = ["jimeng"] + jimeng_args + ["--output-dir", tmp_dir, "--json"]
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        sys.stderr.write(r.stderr or r.stdout)
        sys.exit(r.returncode)
    return r.stdout


def extract_file(jimeng_stdout: str, tmp_dir: str) -> str:
    """Pull the first saved file path out of jimeng's --json output."""
    try:
        payload = json.loads(jimeng_stdout)
    except json.JSONDecodeError:
        sys.stderr.write(f"[dreamina-shim] cannot parse jimeng JSON:\n{jimeng_stdout}\n")
        sys.exit(2)
    data = payload.get("data", {})
    files = data.get("files") or []
    if files:
        return files[0]
    # Fallback: scan the output dir.
    candidates = sorted(pathlib.Path(tmp_dir).glob("*"))
    if candidates:
        return str(candidates[0])
    sys.stderr.write(f"[dreamina-shim] jimeng returned no file:\n{jimeng_stdout}\n")
    sys.exit(2)


def emit(file_path: str):
    abs_path = os.path.abspath(file_path)
    print(json.dumps({
        "result_json": {"images": [{"image_url": f"file://{abs_path}"}]}
    }))


def main():
    sub, kw = parse_args(sys.argv[1:])
    if sub not in ("text2image", "image2image"):
        sys.stderr.write(f"[dreamina-shim] unsupported subcommand: {sub}\n"
                         "supported: text2image, image2image\n")
        sys.exit(2)

    prompt     = kw.get("prompt", "")
    ratio      = kw.get("ratio", "16:9")
    resolution = kw.get("resolution_type", "2k")
    model      = map_model(kw.get("model_version", "5.0"))

    tmp_dir = tempfile.mkdtemp(prefix="dreamina-shim-")

    if sub == "text2image":
        jargs = ["image", "generate",
                 "--prompt", prompt,
                 "--model", model,
                 "--ratio", ratio,
                 "--resolution", resolution]
    else:
        ref = kw.get("images", "")
        if not ref:
            sys.stderr.write("[dreamina-shim] image2image requires --images=PATH\n")
            sys.exit(2)
        jargs = ["image", "edit",
                 "--prompt", prompt,
                 "--image", ref,
                 "--model", model,
                 "--ratio", ratio,
                 "--resolution", resolution]

    out = run_jimeng(jargs, tmp_dir)
    emit(extract_file(out, tmp_dir))


if __name__ == "__main__":
    main()
